        "axios": "^1.10.0",
        "bottleneck": "^2.19.5",
        "dayjs": "^1.11.13"
    },
    "directories": {
        "test": "test"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.7",
        "jest": "^30.0.3",
        "rollup": "^4.44.1",
        "rollup-plugin-typescript2": "^0.36.0",
        "ts-jest": "^29.4.0",
        "tsx": "^4.21.0",
        "typescript": "^5.8.3"
